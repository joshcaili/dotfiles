
-- Filename: lua/plugins/treesitter.lua
return {
  "nvim-treesitter/nvim-treesitter",
  build = ":TSUpdate",
  event = { "BufReadPre", "BufNewFile" },
  opts = {
    ensure_installed = {
      "lua",
      "python",
      "javascript",
      "typescript",
      "markdown",
      "markdown_inline",
      "c",
      "cpp",
    },
    highlight = {
      enable = true,
      additional_vim_regex_highlighting = false, -- set true if you want vim regex highlights in addition
    },
    indent = {
      enable = true, -- optional
    },
  },
  config = function(_, opts)
    require("nvim-treesitter.configs").setup(opts)

    -- Ensure Tree-sitter highlighter is active for markdown files
    vim.api.nvim_create_autocmd("FileType", {
      pattern = "markdown",
      callback = function()
        vim.treesitter.start(0, "markdown")
      end,
    })
  end,
}
